# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key (SERVER ONLY — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin portal password (used to log in at /admin/login)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Public site URL (used for magic link redirects). No trailing slash.
# Local: http://localhost:3000  | Production: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
